---
const sections = [
	{
		title: 'Getting Started',
		href: '/help/getting-started/',
		items: [
			{ label: 'Installation', href: '/help/getting-started/' },
		],
	},
	{
		title: 'Appointments',
		href: '/help/appointments/',
		items: [
			{ label: 'Creating appointments', href: '/help/appointments/creating/' },
			{ label: 'Managing appointments', href: '/help/appointments/managing/' },
		],
	},
	{
		title: 'Bookables',
		href: '/help/bookables/',
		items: [
			{ label: 'Bookable types', href: '/help/bookables/types/' },
			{ label: 'Entities', href: '/help/bookables/entities/' },
			{ label: 'Variants', href: '/help/bookables/variants/' },
		],
	},
	{
		title: 'Availability',
		href: '/help/availability/',
		items: [
			{ label: 'Schedules', href: '/help/availability/schedules/' },
			{ label: 'Layers', href: '/help/availability/layers/' },
		],
	},
	{
		title: 'Customers',
		href: '/help/customers/',
		items: [
			{ label: 'Managing customers', href: '/help/customers/managing/' },
		],
	},
	{
		title: 'Booking Flow',
		href: '/help/booking-flow/',
		items: [
			{ label: 'Gutenberg block', href: '/help/booking-flow/gutenberg-block/' },
		],
	},
	{
		title: 'Notifications',
		href: '/help/notifications/',
		items: [
			{ label: 'Email notifications', href: '/help/notifications/email/' },
		],
	},
	{
		title: 'Settings',
		href: '/help/settings/',
		items: [
			{ label: 'General settings', href: '/help/settings/general/' },
		],
	},
	{
		title: 'Premium',
		href: '/help/premium/',
		badge: true,
		items: [],
	},
];
---

<div class="flex flex-col gap-1">
	{
		sections.map((section) => (
			<div>
				<a
					href={section.href}
					class="flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm font-medium text-text-secondary transition-colors hover:bg-surface"
				>
					{section.title}
					{section.badge && (
						<span class="rounded-md bg-gradient-to-r from-purple-600 to-purple-400 px-1.5 py-0.5 text-[10px] font-semibold text-white leading-none">
							Premium
						</span>
					)}
				</a>
				{section.items.length > 0 && (
					<div class="ml-3 flex flex-col border-l border-border-weak pl-3">
						{section.items.map((item) => (
							<a
								href={item.href}
								class="rounded-lg px-2 py-1 text-sm text-text-tertiary transition-colors hover:bg-surface hover:text-text-secondary"
							>
								{item.label}
							</a>
						))}
					</div>
				)}
			</div>
		))
	}
</div>
