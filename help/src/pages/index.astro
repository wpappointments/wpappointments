---
import HelpLayout from '../layouts/HelpLayout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import SidebarNav from '../components/SidebarNav.astro';
---

<HelpLayout title="Help Center" description="Get answers to common questions about WP Appointments.">
	<SidebarNav slot="sidebar" />

	<div class="flex flex-col items-center pt-10 pb-10 text-center">
		<h1 class="text-4xl font-bold tracking-tight">How can we help?</h1>
		<p class="mt-4 max-w-lg text-lg text-text-secondary">
			Get answers to common questions about setting up and using WP Appointments.
		</p>
	</div>

	<!-- Dashed separator -->
	<svg width="100%" height="1" class="my-10 text-border-subtle">
		<line
			x1="0"
			y1="0.5"
			x2="100%"
			y2="0.5"
			stroke="currentColor"
			stroke-dasharray="4 6"
			stroke-linecap="round"
		/>
	</svg>

	<!-- Category cards -->
	<div class="grid grid-cols-3 gap-5 max-md:grid-cols-1">
		<CategoryCard
			title="Getting Started"
			description="Install, activate, and configure your first appointment system"
			href="/help/getting-started/"
			icon="🚀"
		/>
		<CategoryCard
			title="Appointments"
			description="Create, manage, and track appointments with your customers"
			href="/help/appointments/"
			icon="📅"
		/>
		<CategoryCard
			title="Bookables"
			description="Set up bookable types, entities, and service variants"
			href="/help/bookables/"
			icon="🏢"
		/>
		<CategoryCard
			title="Availability"
			description="Configure schedules, layers, and time-slot rules"
			href="/help/availability/"
			icon="⏰"
		/>
		<CategoryCard
			title="Customers"
			description="Manage customer records and booking history"
			href="/help/customers/"
			icon="👥"
		/>
		<CategoryCard
			title="Booking Flow"
			description="Embed the booking form with the Gutenberg block"
			href="/help/booking-flow/"
			icon="🔄"
		/>
		<CategoryCard
			title="Notifications"
			description="Email confirmations, updates, and cancellations"
			href="/help/notifications/"
			icon="📧"
		/>
		<CategoryCard
			title="Settings"
			description="General plugin settings and configuration"
			href="/help/settings/"
			icon="⚙️"
		/>
		<CategoryCard
			title="Premium Features"
			description="Advanced features available with premium add-ons"
			href="/help/premium/"
			icon="✨"
			premium
		/>
		<CategoryCard
			title="FAQ"
			description="Quick answers to the questions we hear most often"
			href="/help/faq/"
			icon="❓"
		/>
	</div>

	<!-- Dashed separator -->
	<svg width="100%" height="1" class="my-16 text-border-subtle">
		<line
			x1="0"
			y1="0.5"
			x2="100%"
			y2="0.5"
			stroke="currentColor"
			stroke-dasharray="4 6"
			stroke-linecap="round"
		/>
	</svg>

	<!-- Quick links -->
	<div class="flex flex-col gap-6 xl:flex-row xl:justify-between xl:gap-20">
		<div class="max-w-sm">
			<h2 class="text-2xl font-bold">
				Get started <span class="text-text-caption">with WP Appointments.</span>
			</h2>
			<p class="mt-3 text-text-tertiary">
				Everything you need to set up your appointment system.
			</p>
		</div>
		<ol class="flex-1 divide-y divide-border-weak">
			<li class="py-6 first:pt-0">
				<a href="/help/getting-started/" class="group flex gap-6">
					<div
						class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-border-subtle text-sm text-text-caption shadow-sm transition-colors group-hover:border-text-primary"
					>
						1
					</div>
					<div>
						<p class="font-semibold">Installation</p>
						<p
							class="mt-0.5 text-text-tertiary transition-colors group-hover:text-text-secondary"
						>
							Install the plugin and run the setup wizard.
						</p>
					</div>
				</a>
			</li>
			<li class="py-6">
				<a href="/help/bookables/" class="group flex gap-6">
					<div
						class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-border-subtle text-sm text-text-caption shadow-sm transition-colors group-hover:border-text-primary"
					>
						2
					</div>
					<div>
						<p class="font-semibold">Set up services</p>
						<p
							class="mt-0.5 text-text-tertiary transition-colors group-hover:text-text-secondary"
						>
							Create your first services and configure durations.
						</p>
					</div>
				</a>
			</li>
			<li class="py-6">
				<a href="/help/availability/" class="group flex gap-6">
					<div
						class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-border-subtle text-sm text-text-caption shadow-sm transition-colors group-hover:border-text-primary"
					>
						3
					</div>
					<div>
						<p class="font-semibold">Configure availability</p>
						<p
							class="mt-0.5 text-text-tertiary transition-colors group-hover:text-text-secondary"
						>
							Set your weekly schedule and availability rules.
						</p>
					</div>
				</a>
			</li>
		</ol>
	</div>
</HelpLayout>
