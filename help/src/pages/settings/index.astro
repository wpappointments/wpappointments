---
import HelpLayout from '../../layouts/HelpLayout.astro';
import SidebarNav from '../../components/SidebarNav.astro';
---

<HelpLayout
	title="Settings"
	description="Plugin configuration options."
	breadcrumbs={[{ label: 'Settings', href: '/help/settings/' }]}
>
	<SidebarNav slot="sidebar" />

	<header class="mb-12">
		<h1 class="text-4xl font-bold tracking-tight">Settings</h1>
		<p class="mt-4 max-w-2xl text-lg text-text-secondary">
			All configuration is under <strong>WP Appointments &rarr; Settings</strong>.
		</p>
	</header>

	<div class="mt-12 space-y-12">
		<section>
			<h2 class="text-2xl font-semibold">General</h2>
			<div class="mt-4 overflow-hidden rounded-xl border border-border-subtle">
				<table class="w-full text-sm">
					<thead class="bg-surface">
						<tr>
							<th class="px-4 py-3 text-left font-semibold">Setting</th>
							<th class="px-4 py-3 text-left font-semibold">Description</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-border-weak">
						<tr><td class="px-4 py-3">First / Last Name</td><td class="px-4 py-3">Admin contact name used in notifications</td></tr>
						<tr><td class="px-4 py-3">Email</td><td class="px-4 py-3">Admin email for notifications (falls back to WP admin email)</td></tr>
						<tr><td class="px-4 py-3">Phone</td><td class="px-4 py-3">Admin phone for notifications</td></tr>
						<tr><td class="px-4 py-3">Date / Time Format</td><td class="px-4 py-3">Format used in emails and calendar display</td></tr>
						<tr><td class="px-4 py-3">Timezone</td><td class="px-4 py-3">Use site default or override</td></tr>
						<tr><td class="px-4 py-3">Start of Week</td><td class="px-4 py-3">First day of week in calendar views</td></tr>
					</tbody>
				</table>
			</div>
		</section>

		<section>
			<h2 class="text-2xl font-semibold">Appointments</h2>
			<div class="mt-4 overflow-hidden rounded-xl border border-border-subtle">
				<table class="w-full text-sm">
					<thead class="bg-surface">
						<tr>
							<th class="px-4 py-3 text-left font-semibold">Setting</th>
							<th class="px-4 py-3 text-left font-semibold">Description</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-border-weak">
						<tr><td class="px-4 py-3">Service Name</td><td class="px-4 py-3">Default service label</td></tr>
						<tr><td class="px-4 py-3">Default Length</td><td class="px-4 py-3">Appointment duration in minutes</td></tr>
						<tr><td class="px-4 py-3">Time Picker Precision</td><td class="px-4 py-3">Slot interval in minutes (e.g. 15, 30)</td></tr>
						<tr><td class="px-4 py-3">Min Lead Time</td><td class="px-4 py-3">Earliest a customer can book (value + unit)</td></tr>
						<tr><td class="px-4 py-3">Max Lead Time</td><td class="px-4 py-3">Farthest in advance a customer can book (value + unit)</td></tr>
						<tr><td class="px-4 py-3">Default Status</td><td class="px-4 py-3">Confirmed or Pending for new bookings</td></tr>
					</tbody>
				</table>
			</div>
		</section>

		<section>
			<h2 class="text-2xl font-semibold">Schedule</h2>
			<p class="mt-2 text-text-secondary">
				Set opening hours per weekday. Toggle days on/off. Each day can have multiple time slots. See <a href="/help/availability/" class="text-accent underline">Availability</a> for details.
			</p>
		</section>

		<section>
			<h2 class="text-2xl font-semibold">Notifications</h2>
			<p class="mt-2 text-text-secondary">
				Configure email notifications per event. See <a href="/help/notifications/" class="text-accent underline">Notifications</a> for details.
			</p>
		</section>
	</div>
</HelpLayout>
