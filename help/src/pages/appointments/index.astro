---
import HelpLayout from '../../layouts/HelpLayout.astro';
import SidebarNav from '../../components/SidebarNav.astro';
import Callout from '../../components/Callout.astro';
import ScreenshotPlaceholder from '../../components/ScreenshotPlaceholder.astro';
---

<HelpLayout
	title="Appointments"
	description="Create, manage, and track appointments."
	breadcrumbs={[{ label: 'Appointments', href: '/help/appointments/' }]}
>
	<SidebarNav slot="sidebar" />

	<header class="mb-12">
		<h1 class="text-4xl font-bold tracking-tight">Appointments</h1>
		<p class="mt-4 max-w-2xl text-lg text-text-secondary">
			Create, manage, and track appointments with your customers.
		</p>
	</header>

	<Callout>
		<ul>
			<li><strong>Create appointments</strong> — from the admin calendar or let customers book via the booking flow</li>
			<li><strong>Manage statuses</strong> — confirm, cancel, or mark no-shows</li>
			<li><strong>Email notifications</strong> — automatic confirmations and updates</li>
		</ul>
	</Callout>

	<div class="mt-12 space-y-12">
		<section>
			<h2 class="text-2xl font-semibold">Creating Appointments</h2>
			<p class="mt-2 text-text-secondary">
				Appointments link a customer to a service at a specific date and time.
			</p>

			<h3 class="mt-6 text-lg font-semibold">From the Admin Calendar</h3>
			<ol class="mt-3 space-y-3">
				<li class="flex gap-4">
					<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-surface text-xs font-semibold text-text-caption">1</span>
					<p>Go to <strong>WP Appointments → Calendar</strong></p>
				</li>
				<li class="flex gap-4">
					<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-surface text-xs font-semibold text-text-caption">2</span>
					<p>Click a time slot or use the <strong>New Appointment</strong> button</p>
				</li>
				<li class="flex gap-4">
					<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-surface text-xs font-semibold text-text-caption">3</span>
					<p>Select a service, customer, date, and time</p>
				</li>
				<li class="flex gap-4">
					<span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-surface text-xs font-semibold text-text-caption">4</span>
					<p>Click <strong>Save</strong></p>
				</li>
			</ol>

			<ScreenshotPlaceholder description="Admin calendar view with 'New Appointment' slideout panel showing service, customer, date/time fields" />

			<!-- Appointment lifecycle diagram -->
			<div class="mermaid-container">
				<p class="mb-3 text-xs font-semibold uppercase tracking-wider text-text-caption">Appointment Lifecycle</p>
				<pre class="mermaid">
stateDiagram-v2
    [*] --> Pending: Customer books
    [*] --> Confirmed: Admin creates
    Pending --> Confirmed: Admin confirms
    Pending --> Cancelled: Admin/Customer cancels
    Confirmed --> Cancelled: Admin cancels
    Confirmed --> NoShow: Customer doesn't attend
    Confirmed --> [*]: Completed

    classDef pending fill:#fef3c7,stroke:#f59e0b,color:#1f2937
    classDef confirmed fill:#d1fae5,stroke:#34d399,color:#1f2937
    classDef cancelled fill:#fee2e2,stroke:#f87171,color:#1f2937
    classDef noshow fill:#f3f4f6,stroke:#9ca3af,color:#1f2937

    class Pending pending
    class Confirmed confirmed
    class Cancelled cancelled
    class NoShow noshow
				</pre>
			</div>
		</section>

		<section>
			<h2 class="text-2xl font-semibold">Appointment Statuses</h2>
			<div class="mt-4 overflow-hidden rounded-xl border border-border-subtle">
				<table class="w-full text-sm">
					<thead class="bg-surface">
						<tr>
							<th class="px-4 py-3 text-left font-semibold">Status</th>
							<th class="px-4 py-3 text-left font-semibold">Description</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-border-weak">
						<tr>
							<td class="px-4 py-3"><span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-amber-400"></span> Pending</span></td>
							<td class="px-4 py-3 text-text-tertiary">Awaiting confirmation from an admin</td>
						</tr>
						<tr>
							<td class="px-4 py-3"><span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-emerald-400"></span> Confirmed</span></td>
							<td class="px-4 py-3 text-text-tertiary">Appointment is confirmed and scheduled</td>
						</tr>
						<tr>
							<td class="px-4 py-3"><span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-red-400"></span> Cancelled</span></td>
							<td class="px-4 py-3 text-text-tertiary">Appointment was cancelled by admin or customer</td>
						</tr>
						<tr>
							<td class="px-4 py-3"><span class="inline-flex items-center gap-1.5"><span class="h-2 w-2 rounded-full bg-gray-400"></span> No-show</span></td>
							<td class="px-4 py-3 text-text-tertiary">Customer did not attend the appointment</td>
						</tr>
					</tbody>
				</table>
			</div>
		</section>

		<section>
			<h2 class="text-2xl font-semibold">From the Booking Flow</h2>
			<p class="mt-2 text-text-secondary">
				Customers book through the <strong>Booking Flow</strong> block on your website.
			</p>

			<!-- Booking flow diagram -->
			<div class="mermaid-container">
				<p class="mb-3 text-xs font-semibold uppercase tracking-wider text-text-caption">Customer Booking Flow</p>
				<pre class="mermaid">
graph LR
    A[Select Service] --> B[Choose Date]
    B --> C[Pick Time Slot]
    C --> D[Enter Details]
    D --> E[Confirm Booking]
    E --> F[Email Sent]

    style A fill:#e0e7ff,stroke:#818cf8,color:#1f2937
    style B fill:#e0e7ff,stroke:#818cf8,color:#1f2937
    style C fill:#e0e7ff,stroke:#818cf8,color:#1f2937
    style D fill:#e0e7ff,stroke:#818cf8,color:#1f2937
    style E fill:#e0e7ff,stroke:#818cf8,color:#1f2937
    style F fill:#d1fae5,stroke:#34d399,color:#1f2937
				</pre>
			</div>

			<ScreenshotPlaceholder description="Frontend booking flow — multi-step form with service selection, calendar, time slots, and customer details" />
		</section>
	</div>
</HelpLayout>
