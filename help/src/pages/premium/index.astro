---
import HelpLayout from '../../layouts/HelpLayout.astro';
import SidebarNav from '../../components/SidebarNav.astro';
---

<HelpLayout
	title="Premium Features"
	description="Advanced features available with premium add-ons."
	breadcrumbs={[{ label: 'Premium', href: '/help/premium/' }]}
>
	<SidebarNav slot="sidebar" />

	<header class="mb-12">
		<h1 class="text-4xl font-bold tracking-tight">Premium Features</h1>
		<p class="mt-4 max-w-2xl text-lg text-text-secondary">
			The free plugin covers the full booking workflow. Premium add-ons extend it with advanced capabilities.
		</p>
	</header>

	<div class="mt-12 space-y-12">
		<section>
			<h2 class="text-2xl font-semibold">Coming Soon</h2>
			<div class="mt-4 grid grid-cols-2 gap-4 max-md:grid-cols-1">
				<div class="rounded-xl border border-border-weak p-5">
					<h3 class="font-semibold">2-Way Calendar Sync</h3>
					<p class="mt-1 text-sm text-text-tertiary">Google Calendar and Outlook sync to avoid double bookings.</p>
				</div>
				<div class="rounded-xl border border-border-weak p-5">
					<h3 class="font-semibold">Page Builder Integrations</h3>
					<p class="mt-1 text-sm text-text-tertiary">Native Elementor, Bricks, and Divi widgets for the booking flow.</p>
				</div>
				<div class="rounded-xl border border-border-weak p-5">
					<h3 class="font-semibold">Advanced Calendar Views</h3>
					<p class="mt-1 text-sm text-text-tertiary">Week and day views in the admin calendar.</p>
				</div>
				<div class="rounded-xl border border-border-weak p-5">
					<h3 class="font-semibold">Custom Bookable Types</h3>
					<p class="mt-1 text-sm text-text-tertiary">Specialized booking types for specific industries (courts, rooms, vehicles).</p>
				</div>
			</div>
		</section>
	</div>
</HelpLayout>
