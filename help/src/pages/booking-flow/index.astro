---
import HelpLayout from '../../layouts/HelpLayout.astro';
import SidebarNav from '../../components/SidebarNav.astro';
import Callout from '../../components/Callout.astro';
---

<HelpLayout
	title="Booking Flow"
	description="Embed the appointment booking form on your website."
	breadcrumbs={[{ label: 'Booking Flow', href: '/help/booking-flow/' }]}
>
	<SidebarNav slot="sidebar" />

	<header class="mb-12">
		<h1 class="text-4xl font-bold tracking-tight">Booking Flow</h1>
		<p class="mt-4 max-w-2xl text-lg text-text-secondary">
			Four ways to embed the booking calendar on your site.
		</p>
	</header>

	<Callout>
		<ul>
			<li><strong>Gutenberg block</strong> — drag and drop in the block editor</li>
			<li><strong>Shortcode</strong> — <code>[wpappointments]</code> in any editor</li>
			<li><strong>Widget</strong> — classic theme sidebars</li>
			<li><strong>PHP template tag</strong> — direct output in theme files</li>
		</ul>
	</Callout>

	<div class="mt-12 space-y-12">
		<section>
			<h2 id="gutenberg-block" class="text-2xl font-semibold">Gutenberg Block</h2>
			<p class="mt-2 text-text-secondary">
				Search for <strong>Booking Flow</strong> in the block inserter under the <strong>WP Appointments</strong> category.
			</p>
			<div class="mt-4 overflow-hidden rounded-xl border border-border-subtle">
				<table class="w-full text-sm">
					<thead class="bg-surface">
						<tr>
							<th class="px-4 py-3 text-left font-semibold">Setting</th>
							<th class="px-4 py-3 text-left font-semibold">Options</th>
							<th class="px-4 py-3 text-left font-semibold">Default</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-border-weak">
						<tr><td class="px-4 py-3">Flow type</td><td class="px-4 py-3">One Step, Multi Step</td><td class="px-4 py-3">One Step</td></tr>
						<tr><td class="px-4 py-3">Alignment</td><td class="px-4 py-3">Left, Center, Right</td><td class="px-4 py-3">Left</td></tr>
						<tr><td class="px-4 py-3">Width</td><td class="px-4 py-3">Narrow, Full</td><td class="px-4 py-3">Narrow</td></tr>
						<tr><td class="px-4 py-3">Trim unavailable</td><td class="px-4 py-3">On / Off</td><td class="px-4 py-3">On</td></tr>
						<tr><td class="px-4 py-3">Slots as buttons</td><td class="px-4 py-3">On / Off</td><td class="px-4 py-3">Off</td></tr>
					</tbody>
				</table>
			</div>
		</section>

		<section>
			<h2 id="shortcode" class="text-2xl font-semibold">Shortcode</h2>
			<p class="mt-2 text-text-secondary">
				Use in the classic editor, page builders, or anywhere shortcodes work.
			</p>
			<div class="mt-4 rounded-xl border border-border-weak bg-surface p-5">
				<pre class="text-sm"><code>[wpappointments]
[wpappointments flow_type="multi_step" alignment="center" width="full"]
[wpappointments trim_unavailable="0" slots_as_buttons="1"]</code></pre>
			</div>
			<div class="mt-4 overflow-hidden rounded-xl border border-border-subtle">
				<table class="w-full text-sm">
					<thead class="bg-surface">
						<tr>
							<th class="px-4 py-3 text-left font-semibold">Attribute</th>
							<th class="px-4 py-3 text-left font-semibold">Values</th>
							<th class="px-4 py-3 text-left font-semibold">Default</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-border-weak">
						<tr><td class="px-4 py-3"><code>flow_type</code></td><td class="px-4 py-3"><code>one_step</code>, <code>multi_step</code></td><td class="px-4 py-3"><code>one_step</code></td></tr>
						<tr><td class="px-4 py-3"><code>alignment</code></td><td class="px-4 py-3"><code>left</code>, <code>center</code>, <code>right</code></td><td class="px-4 py-3"><code>left</code></td></tr>
						<tr><td class="px-4 py-3"><code>width</code></td><td class="px-4 py-3"><code>narrow</code>, <code>full</code></td><td class="px-4 py-3"><code>narrow</code></td></tr>
						<tr><td class="px-4 py-3"><code>trim_unavailable</code></td><td class="px-4 py-3"><code>1</code>, <code>0</code></td><td class="px-4 py-3"><code>1</code></td></tr>
						<tr><td class="px-4 py-3"><code>slots_as_buttons</code></td><td class="px-4 py-3"><code>1</code>, <code>0</code></td><td class="px-4 py-3"><code>0</code></td></tr>
					</tbody>
				</table>
			</div>
		</section>

		<section>
			<h2 id="widget" class="text-2xl font-semibold">Widget</h2>
			<p class="mt-2 text-text-secondary">
				<strong>WP WP Appointments Flow</strong> widget is available in <strong>Appearance &rarr; Widgets</strong>. Same options as the block, configured via a form.
			</p>
		</section>

		<section>
			<h2 id="php-template-tag" class="text-2xl font-semibold">PHP Template Tag</h2>
			<p class="mt-2 text-text-secondary">
				For theme developers who need direct output in template files.
			</p>
			<div class="mt-4 rounded-xl border border-border-weak bg-surface p-5">
				<pre class="text-sm"><code>&lt;?php wpappointments_render_booking_flow(); ?&gt;

&lt;?php
wpappointments_render_booking_flow( array(
    'flowType'        =&gt; 'MultiStep',
    'alignment'       =&gt; 'Center',
    'trimUnavailable' =&gt; true,
) );
?&gt;</code></pre>
			</div>
			<p class="mt-3 text-sm text-text-tertiary">
				Template tag uses camelCase keys (matching the JS API). Shortcode uses snake_case.
			</p>
		</section>

		<section>
			<h2 class="text-2xl font-semibold">Flow Types</h2>
			<div class="mt-4 grid grid-cols-2 gap-4 max-md:grid-cols-1">
				<div class="rounded-xl border border-border-weak p-5">
					<h3 class="font-semibold">One Step</h3>
					<p class="mt-1 text-sm text-text-tertiary">Calendar, time slots, and customer form on a single page. Best for simple bookings.</p>
				</div>
				<div class="rounded-xl border border-border-weak p-5">
					<h3 class="font-semibold">Multi Step</h3>
					<p class="mt-1 text-sm text-text-tertiary">Step 1: select date/time. Step 2: customer details. Step 3: confirmation. Better for guided flows.</p>
				</div>
			</div>
		</section>
	</div>
</HelpLayout>
