#!/bin/bash
set -euo pipefail

cd "$(dirname "$0")/../plugins/appstip-appointments"
repo_root="$(cd ../.. && pwd)"
dist_dir="$repo_root/dist"
zip_path="$dist_dir/appstip-appointments.zip"

if [ -d vendor-temp ] && [ ! -d vendor ]; then
	echo "Recovering vendor from vendor-temp (prior incomplete run)"
	mv vendor-temp vendor
fi

mkdir -p "$dist_dir"
rm -f "$zip_path"
rm -rf appstip-appointments

version=$(grep -o "Version: *[0-9.]*" appstip-appointments.php | awk '{print $2}')

echo "Releasing version $version"

(cd "$repo_root" && pnpm -C plugins/appstip-appointments build)

restore_vendor() {
	if [ -d vendor-temp ]; then
		rm -rf vendor
		mv vendor-temp vendor
	fi
}
trap restore_vendor EXIT

mv vendor vendor-temp

(cd "$repo_root" && npx wp-env run cli --env-cwd=wp-content/plugins/appstip-appointments composer install --no-dev --quiet)

mkdir appstip-appointments

rsync -a --exclude=appstip-appointments --exclude-from=.zipignore . appstip-appointments

zip -qr "$zip_path" appstip-appointments/* -x@.zipignore

rm -rf appstip-appointments

echo "Release complete ✨ ($zip_path)"
