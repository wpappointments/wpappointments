#!/bin/bash
set -euo pipefail

cd "$(dirname "$0")/../plugins/appointments-booking"
repo_root="$(cd ../.. && pwd)"

if [ -d vendor-temp ] && [ ! -d vendor ]; then
	echo "Recovering vendor from vendor-temp (prior incomplete run)"
	mv vendor-temp vendor
fi

rm -rf appointments-booking.zip appointments-booking

version=$(grep -o "Version: *[0-9.]*" appointments-booking.php | awk '{print $2}')

echo "Releasing version $version"

(cd "$repo_root" && pnpm build)

restore_vendor() {
	if [ -d vendor-temp ]; then
		rm -rf vendor
		mv vendor-temp vendor
	fi
}
trap restore_vendor EXIT

mv vendor vendor-temp

(cd "$repo_root" && npx wp-env run cli --env-cwd=wp-content/plugins/appointments-booking composer install --no-dev --quiet)

mkdir appointments-booking

rsync -a --exclude=appointments-booking --exclude-from=.zipignore . appointments-booking

zip -qr appointments-booking.zip appointments-booking/* -x@.zipignore

rm -rf appointments-booking

echo "Release complete ✨ (appointments-booking.zip)"
